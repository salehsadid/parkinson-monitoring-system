# Parkinson's Tremor and FOG Monitoring & Cueing System
# Environment Configuration

# Application
APP_NAME="Parkinson's Monitoring System"
APP_VERSION="0.1.0"

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./parkinson_monitoring.db

# Data Retention (hours)
RETENTION_HOURS=72

# Logging
LOG_LEVEL=INFO

# Sensor Configuration
DEFAULT_SAMPLING_RATE_HZ=50

# Device Configuration
DEFAULT_DEVICE_ID=ESP32_001
DEFAULT_PATIENT_ID=P001

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=10

# Future: Blynk Integration
# BLYNK_AUTH_TOKEN=
# BLYNK_SERVER=
